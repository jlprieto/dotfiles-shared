{
  "editor.tabSize": 2,
  "editor.indentSize": "tabSize",
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "[python]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },
  "editor.accessibilitySupport": "off",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.autoSave": "onFocusChange",
  "workbench.colorTheme": "Dark Modern",
  "workbench.preferredDarkColorTheme": "Monokai",
  "window.systemColorTheme": "light",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "git.autofetch": true,
  "vim.handleKeys": { "<Tab>": false, "<S-Tab>": false },
  "vim.useCtrlKeys": true,
  "vim.insertModeKeyBindings": [ { "before": ["k", "j"], "after": ["<Esc>"] } ],
  "editor.quickSuggestions": { "other": "off" },
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "editor.wordBasedSuggestions": "off",
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.snippetSuggestions": "none",
  "search.searchView.keywordSuggestions": true,
  "editor.rulers": [80, 120],
  "editor.fontSize": 16,
  "debug.console.fontSize": 16,
  "terminal.integrated.fontSize": 16,
  "chat.editor.fontSize": 14,
  "window.zoomLevel": 1.25,
  "editor.scrollOnMiddleClick": true,
  "debug.inlineValues": "on",
  "redhat.telemetry.enabled": false,
  "terminal.integrated.initialHint": false,
  "chat.viewSessions.orientation": "stacked",
  "security.workspace.trust.untrustedFiles": "open"
}
